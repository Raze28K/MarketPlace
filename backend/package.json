{
  "name": "marketplace-express-postgres-api",
  "version": "1.0.0",
  "description": "Ready-to-use Express + PostgreSQL backend for marketplace web/mobile practice",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "db:init": "psql \"$DATABASE_URL\" -f sql/schema.sql",
    "db:seed": "psql \"$DATABASE_URL\" -f sql/seed.sql"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.22.2",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^9.6.2",
    "morgan": "^1.10.0",
    "pg": "^8.12.0",
    "socket.io": "^4.8.3"
  }
}
